{
  "name": "starter",
  "displayName": "Starter",
  "version": "0.1.0",
  "description": "Minimal educational starter theme",
  "author": "kizu",
  "engine": {
    "version": ">=0.3.0"
  },
  "settings": {
    "accentColor": {
      "type": "color",
      "default": "#2563eb"
    },
    "layout": {
      "type": "select",
      "default": "classic",
      "options": ["classic", "magazine"]
    },
    "showSidebar": {
      "type": "boolean",
      "default": true
    },
    "animation": {
      "type": "select",
      "default": "none",
      "options": ["none", "fade"]
    }
  }
}
